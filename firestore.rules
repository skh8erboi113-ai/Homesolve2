rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * HomeSolve Security Rules
     * Last Updated: 2026-04-24 18:45:00 UTC (Full consolidation refresh)
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidOwnerField(field) {
      return request.resource.data[field] == request.auth.uid;
    }

    function isImmutable(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // --- Collection Rules ---

    /**
     * User profiles: Owners can read/write their own.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; 
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && isImmutable('id');
      allow delete: if isOwner(userId);

      match /draft_listings/{listingId} {
        allow read, write: if isOwner(userId);
      }
    }

    /**
     * Public property listings: Viewable by everyone.
     * Creators must be signed in and assign themselves as owner.
     */
    match /public_property_listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidOwnerField('homeownerId');
      allow update: if isSignedIn() && resource.data.homeownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.homeownerId == request.auth.uid;

      match /images/{imageId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    /**
     * Offers: Shared between proposer, receiver, and listing owner.
     */
    match /offers/{offerId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.proposingUserId || 
        request.auth.uid == resource.data.receivingUserId ||
        request.auth.uid == resource.data.propertyListingHomeownerId
      );
      allow create: if isSignedIn() && isValidOwnerField('proposingUserId');
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.proposingUserId || 
        request.auth.uid == resource.data.receivingUserId
      );
      allow delete: if isSignedIn() && resource.data.proposingUserId == request.auth.uid;
    }

    /**
     * Conversations & Messages: Restricted to participants.
     */
    match /conversations/{conversationId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participantIds;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in resource.data.conversationParticipantIds;
        allow create: if isSignedIn() && request.auth.uid in request.resource.data.conversationParticipantIds;
      }
    }
  }
}