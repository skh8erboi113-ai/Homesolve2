rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * HomeSolve Security Rules
     * 
     * Refreshed to ensure consistent public access to active listings and 
     * synchronized with a consolidated root-level project structure.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isMember(memberList) {
      return isSignedIn() && request.auth.uid in memberList;
    }

    function isValidOwnerField(field) {
      return request.resource.data[field] == request.auth.uid;
    }

    function isImmutable(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // --- Collection Rules ---

    /**
     * User profiles are private to the owner.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; 
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && isImmutable('id');
      allow delete: if isExistingOwner(userId);

      /**
       * Draft listings are private until published.
       */
      match /draft_listings/{listingId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.homeownerId == userId;
        allow update: if isExistingOwner(userId) && isImmutable('homeownerId');
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * Public property listings are viewable by everyone.
     * This rule explicitly allows unauthenticated 'list' and 'get' operations.
     */
    match /public_property_listings/{listingId} {
      allow get, list: if true; 
      allow create: if isSignedIn() && isValidOwnerField('homeownerId');
      allow update: if isExistingOwner(resource.data.homeownerId) && isImmutable('homeownerId');
      allow delete: if isExistingOwner(resource.data.homeownerId);

      match /images/{imageId} {
        allow get, list: if true;
        allow create: if isSignedIn() && isValidOwnerField('listingHomeownerId');
        allow update: if isExistingOwner(resource.data.listingHomeownerId) && isImmutable('listingHomeownerId');
        allow delete: if isExistingOwner(resource.data.listingHomeownerId);
      }
    }

    /**
     * Offers are shared between the proposer, receiver, and property owner.
     */
    match /offers/{offerId} {
      allow get, list: if isSignedIn() && (
        request.auth.uid == resource.data.proposingUserId || 
        request.auth.uid == resource.data.receivingUserId || 
        request.auth.uid == resource.data.propertyListingHomeownerId
      );
      allow create: if isSignedIn() && isValidOwnerField('proposingUserId');
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.proposingUserId || 
        request.auth.uid == resource.data.receivingUserId
      ) && isImmutable('proposingUserId');
      allow delete: if isExistingOwner(resource.data.proposingUserId);
    }

    /**
     * Conversations and Messages are restricted to participants.
     */
    match /conversations/{conversationId} {
      allow get, list: if isMember(resource.data.participantIds);
      allow create: if isSignedIn() && isMember(request.resource.data.participantIds);
      allow update: if isMember(resource.data.participantIds) && isImmutable('participantIds');
      
      match /messages/{messageId} {
        allow get, list: if isMember(resource.data.conversationParticipantIds);
        allow create: if isMember(request.resource.data.conversationParticipantIds) && isValidOwnerField('senderId');
        allow update: if isExistingOwner(resource.data.senderId) && isImmutable('senderId');
        allow delete: if isExistingOwner(resource.data.senderId);
      }
    }

    /**
     * Transactions are private to the buyer and seller.
     */
    match /transactions/{transactionId} {
      allow get, list: if isSignedIn() && (
        request.auth.uid == resource.data.homeownerId || 
        request.auth.uid == resource.data.buyerInvestorId
      );
      allow create: if isSignedIn();
    }
  }
}