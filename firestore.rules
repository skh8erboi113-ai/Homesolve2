rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * HomeSolve Security Rules
     * UPDATED: Enabled Transaction Creation for Participants
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    /**
     * User profiles: Owners can read/write their own.
     */
    match /users/{userId} {
      allow get, create, update, delete: if isOwner(userId);
      allow list: if false; 

      match /draft_listings/{listingId} {
        allow read, write: if isOwner(userId);
      }
    }

    /**
     * Public property listings: Viewable by everyone.
     */
    match /public_property_listings/{listingId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.homeownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.homeownerId == request.auth.uid;

      match /images/{imageId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    /**
     * Offers: Shared between proposer, receiver, and listing owner.
     */
    match /offers/{offerId} {
      allow get, list: if isSignedIn() && (
        request.auth.uid == resource.data.proposingUserId || 
        request.auth.uid == resource.data.receivingUserId ||
        request.auth.uid == resource.data.propertyListingHomeownerId
      );
      allow create: if isSignedIn() && request.resource.data.proposingUserId == request.auth.uid;
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.proposingUserId || 
        request.auth.uid == resource.data.receivingUserId
      );
      allow delete: if isSignedIn() && request.auth.uid == resource.data.proposingUserId;
    }

    /**
     * Conversations & Messages: Restricted to participants.
     */
    match /conversations/{conversationId} {
      allow get, list, update: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participantIds;
      
      match /messages/{messageId} {
        allow get, list: if isSignedIn() && request.auth.uid in resource.data.conversationParticipantIds;
        allow create: if isSignedIn() && request.auth.uid in request.resource.data.conversationParticipantIds;
      }
    }

    /**
     * Transactions: Involved parties can read and create records.
     */
    match /transactions/{transactionId} {
      allow get, list: if isSignedIn() && (
        request.auth.uid == resource.data.homeownerId || 
        request.auth.uid == resource.data.buyerInvestorId
      );
      allow create: if isSignedIn() && (
        request.auth.uid == request.resource.data.homeownerId || 
        request.auth.uid == request.resource.data.buyerInvestorId
      );
      allow update, delete: if false;
    }
  }
}