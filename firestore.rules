rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * HomeSolve Security Rules
     * Last Updated: 2026-04-24 15:15:00 UTC (Fixing public listings permission error)
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isMember(memberList) {
      return isSignedIn() && request.auth.uid in memberList;
    }

    function isValidOwnerField(field) {
      return request.resource.data[field] == request.auth.uid;
    }

    function isImmutable(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // --- Collection Rules ---

    /**
     * User profiles are private to the owner.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; 
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && isImmutable('id');
      allow delete: if isExistingOwner(userId);

      /**
       * Draft listings are private until published.
       */
      match /draft_listings/{listingId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.homeownerId == userId;
        allow update: if isExistingOwner(userId) && isImmutable('homeownerId');
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * Public property listings are viewable by everyone.
     * We explicitly allow 'get' and 'list' to ensure queries are valid for all users.
     */
    match /public_property_listings/{listingId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isValidOwnerField('homeownerId');
      allow update: if isSignedIn() && 
                   resource.data.get('homeownerId', '') == request.auth.uid && 
                   isImmutable('homeownerId');
      allow delete: if isSignedIn() && resource.data.get('homeownerId', '') == request.auth.uid;

      match /images/{imageId} {
        allow read: if true;
        allow create: if isSignedIn() && isValidOwnerField('listingHomeownerId');
        allow update: if isSignedIn() && 
                     resource.data.get('listingHomeownerId', '') == request.auth.uid && 
                     isImmutable('listingHomeownerId');
        allow delete: if isSignedIn() && resource.data.get('listingHomeownerId', '') == request.auth.uid;
      }
    }

    /**
     * Offers are shared between the proposer, receiver, and property owner.
     */
    match /offers/{offerId} {
      allow get, list: if isSignedIn() && (
        request.auth.uid == resource.data.get('proposingUserId', '') || 
        request.auth.uid == resource.data.get('receivingUserId', '') || 
        request.auth.uid == resource.data.get('propertyListingHomeownerId', '')
      );

      allow create: if isSignedIn() && isValidOwnerField('proposingUserId');
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.get('proposingUserId', '') || 
        request.auth.uid == resource.data.get('receivingUserId', '')
      ) && isImmutable('proposingUserId');
      allow delete: if isSignedIn() && resource.data.get('proposingUserId', '') == request.auth.uid;
    }

    /**
     * Conversations and Messages are restricted to participants.
     */
    match /conversations/{conversationId} {
      allow get, list: if isSignedIn() && request.auth.uid in resource.data.get('participantIds', []);
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.get('participantIds', []);
      allow update: if isSignedIn() && 
                   request.auth.uid in resource.data.get('participantIds', []) && 
                   isImmutable('participantIds');
      
      match /messages/{messageId} {
        allow get, list: if isSignedIn() && request.auth.uid in resource.data.get('conversationParticipantIds', []);
        allow create: if isSignedIn() && 
                     request.auth.uid in request.resource.data.get('conversationParticipantIds', []) && 
                     isValidOwnerField('senderId');
        allow update: if isSignedIn() && 
                     resource.data.get('senderId', '') == request.auth.uid && 
                     isImmutable('senderId');
        allow delete: if isSignedIn() && resource.data.get('senderId', '') == request.auth.uid;
      }
    }

    /**
     * Transactions are private to the buyer and seller.
     */
    match /transactions/{transactionId} {
      allow get, list: if isSignedIn() && (
        request.auth.uid == resource.data.get('homeownerId', '') || 
        request.auth.uid == resource.data.get('buyerInvestorId', '')
      );
      allow create: if isSignedIn();
    }
  }
}