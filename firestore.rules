
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * HomeSolve Production Security Rules
     * DEPLOYED: 2024-06-21T15:00:00Z
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get, create, update: if isOwner(userId);
      allow list: if false; 

      match /draft_listings/{listingId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /public_property_listings/{listingId} {
      // Allow everyone to browse active listings
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.homeownerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.homeownerId == request.auth.uid;
      allow delete: if false; // Prefer marking as 'delisted' instead of hard delete

      match /images/{imageId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    match /offers/{offerId} {
      // Participating parties can see the offer
      allow get, list: if isSignedIn() && (
        request.auth.uid == resource.data.proposingUserId || 
        request.auth.uid == resource.data.receivingUserId ||
        request.auth.uid == resource.data.propertyListingHomeownerId
      );
      allow create: if isSignedIn() && request.resource.data.proposingUserId == request.auth.uid;
      // Homeowner or Investor can update status (accept/reject/counter)
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.proposingUserId || 
        request.auth.uid == resource.data.receivingUserId
      );
      allow delete: if false;
    }

    match /conversations/{conversationId} {
      allow get, list, update: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participantIds;
      
      match /messages/{messageId} {
        allow get, list: if isSignedIn() && request.auth.uid in resource.data.conversationParticipantIds;
        allow create: if isSignedIn() && request.auth.uid in request.resource.data.conversationParticipantIds;
      }
    }

    match /transactions/{transactionId} {
      // Visible only to the parties involved or platform admin (rules don't have roles yet, so parties only)
      allow get, list: if isSignedIn() && (
        request.auth.uid == resource.data.homeownerId || 
        request.auth.uid == resource.data.buyerInvestorId
      );
      // Created automatically during closing flow
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
